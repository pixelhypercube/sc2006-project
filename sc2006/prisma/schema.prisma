// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String        @id @default(cuid())
  name                    String
  password                String
  email                   String        @unique
  role                    Role          @default(OWNER)
  verified                Boolean       @default(false)
  status                  AccountStatus @default(ACTIVE)
  phone                   String?       @unique
  biography               String?       @db.Text
  location                String?
  latitude                Float?
  longitude               Float?
  avatar                  String?
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")
  verificationToken       String?       @unique
  verificationTokenExpiry DateTime?

  // Relations
  pets                   Pet[]
  ownerBookings          Booking[]               @relation("OwnerBookings")
  caregiverBookings      Booking[]               @relation("CaregiverBookings")
  caregiverProfile       CaregiverProfile?
  sentReviews            Review[]                @relation("ReviewSender")
  receivedReviews        Review[]                @relation("ReviewReceiver")
  sentMessages           Message[]               @relation("MessageSender")
  receivedMessages       Message[]               @relation("MessageReceiver")
  messages               Message[]
  notifications          Notification[]
  availability           Availability[]
  availabilityExceptions AvailabilityException[]

  @@index([role])
  @@index([latitude, longitude])
  @@map("users")
}

model CaregiverProfile {
  id                  String    @id @default(cuid())
  name                String
  user                User      @relation(fields: [id], references: [id], onDelete: Cascade)
  biography           String?   @db.Text
  dailyRate           Float     @map("daily_rate")
  petPreferences      PetType[]
  dogSizes            DogSize[]  @map("dog_sizes")
  services            ServiceType[]
  location            String?
  experienceYears     Int?      @map("experience_years")
  isAcceptingRequests Boolean   @default(true) @map("is_accepting_requests")
  verified            Boolean   @default(false)
  verificationDoc     String?   @map("verification_doc")
  averageRating       Float     @default(0) @map("average_rating")
  totalReviews        Int       @default(0) @map("total_reviews")
  completedBookings   Int       @default(0) @map("completed_bookings")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("caregiver_profiles")
}

model Pet {
  id                String   @id @default(cuid())
  ownerId           String   @map("owner_id")
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name              String
  type              String
  breed             String?
  vaccinationStatus String?
  age               Int?
  weight            Float?
  specialNeeds      String?  @map("special_needs") @db.Text
  photo             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  bookings Booking[]

  @@index([ownerId])
  @@index([type])
  @@map("pets")
}

model Booking {
  id                  String        @id @default(cuid())
  ownerId             String        @map("owner_id")
  caregiverId         String        @map("caregiver_id")
  petId               String        @map("pet_id")
  startDate           DateTime      @map("start_date")
  endDate             DateTime      @map("end_date")
  status              BookingStatus @default(PENDING)
  totalPrice          Float         @map("total_price")
  specialInstructions String?       @map("special_instructions") @db.Text
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  owner     User      @relation("OwnerBookings", fields: [ownerId], references: [id])
  caregiver User      @relation("CaregiverBookings", fields: [caregiverId], references: [id])
  pet       Pet       @relation(fields: [petId], references: [id])
  review    Review?
  payment   Payment?
  messages  Message[]

  @@unique([ownerId, caregiverId, petId, startDate])
  @@index([caregiverId, status])
  @@index([ownerId, status])
  @@index([startDate, endDate])
  @@map("bookings")
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique @map("booking_id")
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  fromUser User @relation("ReviewSender", fields: [fromUserId], references: [id])
  toUser   User @relation("ReviewReceiver", fields: [toUserId], references: [id])

  @@index([toUserId, rating])
  @@map("reviews")
}

model Availability {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int?     @map("day_of_week") // 0-6, null for custom dates
  startTime DateTime // Time stored as DateTime with same date
  endTime   DateTime
  recurring Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, dayOfWeek, startTime, endTime])
  @@index([userId, recurring])
  @@map("availability")
}

model AvailabilityException {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  available Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@map("availability_exceptions")
}

model Chat {
  senderId   String @map("sender_id")
  receiverId String @map("receiver_id")

  @@unique([senderId, receiverId])
  @@index([senderId, receiverId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  receiver  User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?

  @@index([senderId, receiverId])
  @@index([createdAt])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json? // Store additional data as JSON
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique @map("booking_id")
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount                Float
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeCustomerId      String?       @map("stripe_customer_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  paidAt                DateTime?     @map("paid_at")
  refundedAt            DateTime?     @map("refunded_at")

  @@index([status])
  @@map("payments")
}

// Enums
enum Role {
  OWNER
  CAREGIVER
  ADMIN
}

enum PetType {
  DOG
  CAT
  BIRD
  FISH
  REPTILE
  SMALL_ANIMAL
  OTHER
}

enum DogSize {
  SMALL
  MEDIUM
  LARGE
}

enum ServiceType {
  BOARDING
  HOUSE_SITTING
  DROP_IN
  DAYCARE
  WALKING
  BATHING
  NAILS
  EARS
  TEETH
  DESHEDDING
  TRAINING_PUPPY
  TRAINING_OBEDIENCE
  TRAINING_BEHAVIOR
  TRAINING_AGILITY
  MED_ORAL
  MED_INJECT
  MED_RECOVERY
  MED_SENIOR
  MED_WOUND
  TAXI
  WEDDING
  CLEANING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DECLINED
}

enum NotificationType {
  WELCOME
  NEW_BOOKING
  BOOKING_ACCEPTED
  BOOKING_DECLINED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  NEW_MESSAGE
  NEW_REVIEW
  PAYMENT_RECEIVED
  PAYMENT_REFUNDED
  CAREGIVER_VERIFIED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  LOCKED
}
